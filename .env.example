# ─────────────────────────────────────────────────────────────
# KinCode environment variables
# Copy this file to ".env" and fill in your real values for LOCAL dev.
# NEVER commit your real .env (it is gitignored).
# ─────────────────────────────────────────────────────────────

# Firebase config (safe to expose — these identify your project, not secrets)
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=kincode-xxxxx.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://kincode-xxxxx-default-rtdb.firebaseio.com
VITE_FIREBASE_PROJECT_ID=kincode-xxxxx
VITE_FIREBASE_STORAGE_BUCKET=kincode-xxxxx.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Gemini — LOCAL DEV ONLY.
# This key is used for the direct-call fallback when running `npm run dev`.
# In PRODUCTION (Vercel), do NOT set this. Instead set GEMINI_API_KEY
# (no VITE_ prefix) in the Vercel dashboard so the /api/gemini proxy can use it
# server-side and the key never ships to the browser.
VITE_GEMINI_API_KEY=your_gemini_key_for_local_dev_only

# PRODUCTION (set this in Vercel project settings, NOT here):
# GEMINI_API_KEY=your_gemini_key
